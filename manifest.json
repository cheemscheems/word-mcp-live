{
  "manifest_version": "0.3",
  "name": "word-mcp-live-cheemscheems",
  "version": "1.6.20",
  "description": "MCP server for Microsoft Word — live editing on Windows (COM) and macOS (JXA), plus cross-platform python-docx tools. Security-hardened fork.",
  "author": {
    "name": "cheemscheems",
    "url": "https://github.com/cheemscheems"
  },
  "repository": {
    "url": "https://github.com/cheemscheems/word-mcp-live",
    "type": "git"
  },
  "license": "MIT",
  "server": {
    "type": "python",
    "entry_point": "word_mcp_server.py",
    "mcp_config": {
      "command": "uvx",
      "args": ["word-mcp-live-cheemscheems"],
      "env": {
        "MCP_AUTHOR": "Author",
        "MCP_AUTHOR_INITIALS": ""
      }
    }
  },
  "keywords": ["word", "docx", "microsoft-word", "document", "com-automation", "tracked-changes", "live-editing", "security-hardened"]
}
